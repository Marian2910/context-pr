CONTEXTPR_LOG_LEVEL=INFO

# GitHub configuration
CONTEXTPR_GITHUB_TOKEN=replace-with-github-token
CONTEXTPR_GITHUB_API_URL=https://api.github.com
CONTEXTPR_GITHUB_REPOSITORY=owner/repository

# SonarQube / SonarCloud configuration
CONTEXTPR_SONAR_TOKEN=replace-with-sonar-token
CONTEXTPR_SONAR_HOST_URL=https://sonarcloud.io
CONTEXTPR_SONAR_ORGANIZATION=your-organization
CONTEXTPR_SONAR_PROJECT_KEY=your-project-key
